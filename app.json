{
  "expo": {
    "name": "meu-projeto-mobile",
    "slug": "meu-projeto-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "meuprojetomobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysPermissionMsg": "Permitir que o ProMatch acesse sua localização para sugerir profissionais próximos.",
          "locationWhenInUsePermissionMsg": "Precisamos da sua localização para preencher seu endereço e encontrar matches próximos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o ProMatch acesse suas fotos para o perfil e portfólio.",
          "cameraPermission": "Permitir que o ProMatch use sua câmera para tirar uma nova foto de perfil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68c9d53d-f746-47f5-aee7-238548d79f91"
      }
    }
  }
}
